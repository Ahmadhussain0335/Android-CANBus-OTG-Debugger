<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.usb.host"/>

    <application
        android:name=".CanApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CANApp">

        <activity
            android:name=".ui.devicelist.DeviceListActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="@string/app_name"
            android:theme="@style/Theme.CANApp.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"/>
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter"/>
        </activity>

        <activity
            android:name=".ui.configure.ConfigureActivity"
            android:exported="false"
            android:label="Configure connection"/>

        <activity
            android:name=".ui.command.CommandActivity"
            android:exported="false"
            android:label="Send commands"
            android:windowSoftInputMode="adjustPan"/>

        <activity
            android:name=".ui.library.SavedCommandsActivity"
            android:exported="false"
            android:label="Saved Commands"
            android:windowSoftInputMode="adjustPan"/>

    </application>

</manifest>
