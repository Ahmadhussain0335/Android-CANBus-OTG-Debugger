<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_primary_dark"
        android:elevation="4dp"
        app:title="Command Library"
        app:titleTextColor="@android:color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Add command form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.1"
                android:text="New Command"
                android:textAllCaps="true"
                android:textColor="@color/color_primary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/editCommandName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_outline"
                    android:hint="Command name"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textSize="13sp"/>

                <EditText
                    android:id="@+id/editCommandCanId"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edit_text_outline"
                    android:fontFamily="monospace"
                    android:hint="CAN ID"
                    android:inputType="textNoSuggestions"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textSize="13sp"/>

            </LinearLayout>

            <EditText
                android:id="@+id/editCommandData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/edit_text_outline"
                android:fontFamily="monospace"
                android:hint="Data bytes (hex, e.g. 02 01 0C)"
                android:inputType="textNoSuggestions"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textSize="13sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add in List"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/color_info"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="6dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"/>

        <!-- Saved commands section header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.1"
                android:text="Saved Commands"
                android:textAllCaps="true"
                android:textColor="@color/color_primary"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="20dp"
            android:text="No commands saved yet"
            android:textColor="@color/color_secondary"
            android:textSize="13sp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSavedCommands"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/surface"/>

        <!-- Send button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            android:text="Send Selected"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:backgroundTint="@color/color_success"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="6dp"/>

        <!-- Log header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/log_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.12"
                android:text="Log"
                android:textAllCaps="true"
                android:textColor="@color/color_info"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Adapter info"
                android:textColor="@color/log_text_muted"
                android:textSize="11sp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchPeakLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:checked="false"/>

            <ImageButton
                android:id="@+id/btnClearLog"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear log"
                android:src="@drawable/ic_clear_log"
                app:tint="@color/log_text_muted"/>

        </LinearLayout>

        <!-- Terminal log -->
        <ScrollView
            android:id="@+id/scrollViewLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/log_background"
            android:paddingHorizontal="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"
                android:textColor="#C9D1D9"
                android:textSize="11sp"/>

        </ScrollView>

    </LinearLayout>

</LinearLayout>
