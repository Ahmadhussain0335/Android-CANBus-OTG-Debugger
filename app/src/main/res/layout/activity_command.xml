<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_primary_dark"
        android:elevation="4dp"
        app:title="Send Commands"
        app:titleTextColor="@android:color/white">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDisconnect"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="4dp"
            android:text="Disconnect"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:backgroundTint="@android:color/transparent"
            app:rippleColor="#44FFFFFF"
            app:strokeColor="#66FFFFFF"
            app:strokeWidth="1dp"/>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Connected status chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_connected"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="7dp"
                android:background="@drawable/dot_green"/>

            <TextView
                android:id="@+id/tvConnectionInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:textColor="@color/color_success"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="0dp">

        <!-- Commands header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.1"
                android:text="Commands"
                android:textAllCaps="true"
                android:textColor="@color/color_primary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMoreDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp"
                android:text="More Details →"
                android:textColor="@color/color_info"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddCommand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="+ Add"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:backgroundTint="@color/color_info"
                app:cornerRadius="8dp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCommands"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:clipToPadding="false"
            android:paddingEnd="8dp"/>

        <!-- Log header bar (part of the terminal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/log_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.12"
                android:text="Log"
                android:textAllCaps="true"
                android:textColor="@color/color_info"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Adapter info"
                android:textColor="@color/log_text_muted"
                android:textSize="11sp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchPeakLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:checked="false"/>

            <ImageButton
                android:id="@+id/btnClearLog"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear log"
                android:src="@drawable/ic_clear_log"
                app:tint="@color/log_text_muted"/>

        </LinearLayout>

        <!-- Terminal log body -->
        <ScrollView
            android:id="@+id/scrollViewLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/log_background"
            android:paddingHorizontal="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"
                android:textColor="#C9D1D9"
                android:textSize="11sp"/>

        </ScrollView>

    </LinearLayout>

</LinearLayout>
