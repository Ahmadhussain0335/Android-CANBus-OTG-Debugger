<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_primary_dark"
        android:elevation="4dp"
        app:title="CAN Commander"
        app:titleTextColor="@android:color/white"/>

    <!-- Hero header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_primary"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.12"
            android:text="USB CAN ADAPTER"
            android:textAllCaps="true"
            android:textColor="#BBDEFB"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Plug in a SLCAN or PEAK USB device via OTG cable, then tap Scan"
            android:textColor="#E3F2FD"
            android:textSize="13sp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"/>

    <View
        android:id="@+id/logDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/log_background"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvScanLogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/log_background"
        android:letterSpacing="0.12"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:text="SCAN LOG"
        android:textAllCaps="true"
        android:textColor="@color/color_info"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <ScrollView
        android:id="@+id/scrollScanLog"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/log_background"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvScanLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3"
            android:padding="10dp"
            android:textColor="#C9D1D9"
            android:textSize="11sp"/>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Scan for Devices"
        android:textAllCaps="false"
        android:textSize="15sp"
        app:backgroundTint="@color/color_primary"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_scan"
        app:iconGravity="textStart"
        app:iconPadding="8dp"/>

</LinearLayout>
